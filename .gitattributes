# Treat Godot resource files as text
*.gd      text eol=lf
*.tscn    text eol=lf
*.tres    text eol=lf
*.cfg     text eol=lf
*.import  text eol=lf

# Binary asset formats
*.glb     binary
*.gltf    binary
*.blend   binary
*.fbx     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.webp    binary
*.ogg     binary
*.wav     binary
*.mp3     binary
